<div class="max-w-md mx-auto px-2 mt-12 mb-4">
  <div class="space-y-6 mx-auto">
    <div class="space-y-6">
      <div class="flex items-center justify-center">
        <%# Muestra tu logo si lo subiste en la configuración %>
        <%= render 'banner' %>
      </div>
      <div class="flex items-center bg-base-200 rounded-xl p-4 mb-4 text-center">
        <div class="w-full">
          <p dir="auto" class="text-lg font-bold mb-1"><%= @submitter.submission.template.name %></p>
          <p dir="auto" class="text-sm text-success font-semibold">
            ✅ Formulario completado correctamente
          </p>
        </div>
      </div>
    </div>

    <div dir="auto" class="text-center py-4">
      <h2 class="text-3xl font-bold mb-2 text-primary">¡Ya has votado!</h2>
      <p class="text-lg text-gray-600">Tu voto ya ha sido registrado correctamente.</p>
      <p class="mt-6 text-sm text-gray-400 italic">Ya puedes cerrar esta ventana.</p>
    </div>

    <%# Botón opcional por si el socio quiere el PDF en su correo (sin mostrar el mail en pantalla) %>
    <% if Docuseal.multitenant? || Accounts.can_send_emails?(@submitter.account) %>
      <toggle-submit class="block mt-4">
        <%= button_to button_title(title: "Recibir copia por email", disabled_with: "Enviando...", icon: svg_icon('mail_forward', class: 'w-6 h-6')), send_submission_email_index_path, params: { template_slug: @template.slug, email: @submitter.email }, class: 'base-button w-full' %>
      </toggle-submit>
    <% end %>

    <%# ELIMINADO EL BOTÓN DE REENVIAR %>
  </div>
</div>

<%# ELIMINADA LA ATRIBUCIÓN DE DOCUSEAL %>
