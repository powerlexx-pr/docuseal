<div class="max-w-md mx-auto px-2 mt-12 mb-4">
  <div class="space-y-6 mx-auto">
    <div class="space-y-6">
      <div class="flex items-center justify-center">
        <%# Muestra tu logo si lo subiste en la configuración %>
        <%= render 'banner' %>
      </div>
      
      <%# Encabezado del Referéndum con bordes y letras blancas %>
      <div class="flex items-center bg-transparent rounded-xl p-6 mb-4 text-center border-2" style="border-color: #ffffff;">
        <div class="w-full">
          <p dir="auto" class="text-lg font-bold mb-2" style="color: #ffffff;">
            Referéndum Universidad Complutense de Madrid - 16 de abril
          </p>
          <p dir="auto" style="color: #ffffff; font-size: 1.875rem; line-height: 2.25rem; font-weight: 900; text-transform: uppercase;">
            Voto registrado correctamente
          </p>
        </div>
      </div>
    </div>

    <%# Pregunta Central en Blanco %>
    <div dir="auto" class="text-center py-8">
      <h2 class="text-4xl font-extrabold mb-4" style="color: #ffffff;">
        ¿Paramos el plan de recortes?
      </h2>
      <p class="mt-10 font-medium" style="color: #ffffff;">Ya puedes cerrar esta ventana.</p>
    </div>

    <%# Botón: Fondo blanco con texto en verde para que contraste %>
    <% if Docuseal.multitenant? || Accounts.can_send_emails?(@submitter.account) %>
      <toggle-submit class="block mt-4">
        <%= button_to button_title(title: "Recibir justificante por email", disabled_with: "Enviando...", icon: svg_icon('mail_forward', class: 'w-6 h-6')), 
            send_submission_email_index_path, 
            params: { template_slug: @template.slug, email: @submitter.email }, 
            class: 'base-button w-full',
            style: 'background-color: #ffffff; border-color: #ffffff; color: #00bf63; font-weight: bold;' %>
      </toggle-submit>
    <% end %>

  </div>
</div>
