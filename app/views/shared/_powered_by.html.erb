<div class="text-center px-2">
  <% if local_assigns[:with_counter] %>
    <% count = CompletedSubmitter.distinct.count(:submission_id) %>
    <% if count > 1 %>
      <%= t('count_documents_signed_with_html', count:) %>
    <% else %>
      <%= t('powered_by') %>
    <% end %>
  <% else %>
    <%= t('powered_by') %>
  <% end %>
  <a href="https://github.com/powerlexx-pr/docuseal" class="underline">DocuSeal UCMXLAPUBLICA Edition</a> - <%= t('open_source_documents_software') %>
</div>
